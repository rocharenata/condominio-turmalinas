<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Condomínio Turmalinas</title>
    <link rel="stylesheet" href="style.css">
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        /* Estilos para a tela de login */
        .login-screen { display: flex; justify-content: center; align-items: center; min-height: 100vh; background-color: #f0f8ff; }
        .login-card { background: white; padding: 40px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); text-align: center; }
        .btn-google { background-color: #4285F4; color: white; border: none; padding: 15px 30px; border-radius: 8px; font-size: 18px; cursor: pointer; font-weight: bold; }
        
        /* Layout Geral */
        #conteudo-privado { display: none; padding: 20px; max-width: 900px; margin: 0 auto; }
        header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; background: white; padding: 15px; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        
        /* Seção de Cadastro (No Topo) */
        .cadastro-section { margin-bottom: 30px; background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.08); border-left: 5px solid #22a6b3; }
        .cadastro-section h3 { margin-top: 0; color: #333; }
        
        /* Tabelas e Botões */
        .tab-button { transition: background 0.3s; font-weight: bold; }
        .tab-button:hover { opacity: 0.8; }
        table th { border-radius: 5px 5px 0 0; }
    </style>
</head>
<body>

    <div id="tela-login" class="login-screen">
        <div class="login-card">
            <div style="font-size: 60px;">💎</div>
            <h1>Condomínio Turmalinas</h1>
            <p>Acesse com seu e-mail do Google para ver os moradores.</p>
            <button class="btn-google" onclick="loginGoogle()">Entrar com Google</button>
        </div>
    </div>

    <div id="conteudo-privado">
        <header>
            <span>Bem-vindo, <strong id="user-email" style="color: #22a6b3;"></strong></span>
            <button onclick="logout()" style="background:#ff4d4d; color:white; border:none; padding:8px 15px; border-radius:5px; cursor:pointer; font-weight:bold;">Sair</button>
        </header>

        <div class="cadastro-section">
            <h3>➕ Cadastrar Novo Morador</h3>
            <form id="formMorador" style="display: flex; gap: 10px; flex-wrap: wrap;">
                <input type="number" id="apto" placeholder="Apto" required style="flex: 1; min-width: 80px; padding: 12px; border: 1px solid #ddd; border-radius: 8px;">
                <input type="text" id="morador" placeholder="Nome do morador" required style="flex: 3; min-width: 200px; padding: 12px; border: 1px solid #ddd; border-radius: 8px;">
                <button type="submit" style="padding: 12px 20px; background: #22a6b3; color: white; border: none; border-radius: 8px; cursor: pointer; font-weight:bold;">Cadastrar</button>
            </form>
        </div>

        <div class="navigation-tabs" style="display: flex; gap: 10px; margin-bottom: 20px;">
            <button class="tab-button" onclick="carregarTorre(1)" style="flex:1; padding: 15px; background: #22a6b3; color: white; border: none; border-radius: 10px; cursor: pointer;">Torre 1</button>
            <button class="tab-button" onclick="carregarTorre(2)" style="flex:1; padding: 15px; background: #22a6b3; color: white; border: none; border-radius: 10px; cursor: pointer;">Torre 2</button>
            <button class="tab-button" onclick="carregarTorre(3)" style="flex:1; padding: 15px; background: #22a6b3; color: white; border: none; border-radius: 10px; cursor: pointer;">Torre 3</button>
        </div>

        <div class="content-section" style="background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <h2 id="tituloTorre" style="color: #2c3e50;">Torre 1</h2>
            <table style="width: 100%; border-collapse: collapse;">
                <thead style="background: #22a6b3; color: white;">
                    <tr>
                        <th style="padding: 12px; text-align: left;">Apartamento</th>
                        <th style="padding: 12px; text-align: left;">Moradores</th>
                    </tr>
                </thead>
                <tbody id="listaMoradores">
                    </tbody>
            </table>
        </div>
        
        <div style="margin-top: 20px; text-align: center;">
            <a href="orcamentos.html" style="color: #22a6b3; text-decoration: none; font-weight: bold;">📋 Ir para Orçamentos e Indicações</a>
        </div>
    </div>

    <script>
        // Configuração Supabase
        const _supabaseUrl = 'https://fmluskuoyzgnzbxsllum.supabase.co';
        const _supabaseKey = 'sb_publishable_HkaCJSZoX-0CcP7Vr8teyA_ia7VMm3xS_82HqE6_HkaCJSZoX';
        const db = supabase.createClient(_supabaseUrl, _supabaseKey);

        let torreAtual = 1;

        // LOGIN / LOGOUT
        async function loginGoogle() {
            await db.auth.signInWithOAuth({
                provider: 'google',
                options: { redirectTo: 'https://rocharenata.github.io/condominio-turmalinas/' }
            });
        }

        async function logout() {
            await db.auth.signOut();
            window.location.reload();
        }

        // VERIFICAR SESSÃO
        async function checarSessao() {
            const { data: { user } } = await db.auth.getUser();
            if (user) {
                document.getElementById('tela-login').style.display = 'none';
                document.getElementById('conteudo-privado').style.display = 'block';
                document.getElementById('user-email').innerText = user.email;
                carregarTorre(1); 
            } else {
                document.getElementById('tela-login').style.display = 'flex';
                document.getElementById('conteudo-privado').style.display = 'none';
            }
        }

       // BUSCAR MORADORES DA TORRE (Ajustado com organização automática)
async function carregarTorre(numero) {
    torreAtual = numero;
    document.getElementById("tituloTorre").innerText = "Torre " + numero;
    const listaCorpo = document.getElementById("listaMoradores");
    listaCorpo.innerHTML = "<tr><td colspan='2'>Carregando...</td></tr>";

    try {
        const { data, error } = await db
            .from('moradores')
            .select('*')
            .or(`Torre.eq.Torre ${numero},Torre.eq.${numero}`)
            // ABAIXO: A linha que faz a mágica de organizar por número
            .order('Apartamento', { ascending: true });

        if (error) throw error;

        let html = "";
        if (data && data.length > 0) {
            data.forEach(m => {
                const apto = m.Apartamento || m.apto || "---";
                const nome = m.Moradores || m.morador || "---";
                html += `<tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 12px;">${apto}</td>
                            <td style="padding: 12px;">${nome}</td>
                         </tr>`;
            });
        } else {
            html = "<tr><td colspan='2' style='padding: 20px; text-align: center;'>Nenhum morador encontrado.</td></tr>";
        }
        listaCorpo.innerHTML = html;
    } catch (err) {
        listaCorpo.innerHTML = `<tr><td colspan='2' style='color:red'>Erro ao carregar dados.</td></tr>`;
    }
}
    </script>
</body>
</html>